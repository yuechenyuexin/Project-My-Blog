# ==============================================
# 🔥 核心敏感文件（绝对禁止上传 GitHub）
# ==============================================
# 环境变量（数据库密码、密钥、配置）
.env
.env.*
!.env.example

# ==============================================
# 🐍 Python 项目缓存/编译文件（自动生成，无用）
# ==============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
ENV/
env.bak/
venv.bak/

# ==============================================
# 📊 数据库 / Alembic 迁移相关
# ==============================================
# Alembic 缓存文件（保留 versions 迁移脚本！）
alembic/__pycache__/
# 本地数据库文件（如果用 SQLite 才会生成，MySQL 无）
*.db
*.sqlite3
# 数据库日志
*.sql

# ==============================================
# 📝 编辑器 / IDE 配置（个人配置，无需上传）
# ==============================================
# VS Code
.vscode/
*.code-workspace
# PyCharm
.idea/
# 系统临时文件
.DS_Store
Thumbs.db
*.swp
*.swo

# ==============================================
# 🚀 项目运行文件（日志/临时文件）
# ==============================================
# 日志文件
logs/
*.log
# 临时缓存
temp/
tmp/
# 上传的静态文件（如果有）
uploads/
media/

# ==============================================
# 📦 Python 打包/分发文件
# ==============================================
dist/
build/
*.egg-info/
.installed.cfg
*.egg

# ==============================================
# ❌ 其他无用文件
# ==============================================
*.bak
*.tmp
*.old