# ==============================
# AI_BLOG 项目环境变量模板
# 请复制此文件为 .env 并填写真实配置
# ==============================

# 数据库配置
DB_USER=你的数据库用户名（例如 root）
DB_PASSWORD=你的数据库密码
DB_HOST=数据库地址（例如 localhost 或 127.0.0.1）
DB_PORT=数据库端口（例如 3306 或 3307）
DB_NAME=你的数据库名（例如 ai_blog）
DB_CHARSET=utf8mb4（默认字符集，一般无需修改）

# JWT 认证配置
JWT_SECRET_KEY=生成的随机密钥（生产环境请用 `openssl rand -hex 32` 生成）
JWT_ALGORITHM=HS256（默认加密算法）
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30（访问令牌过期时间，单位：分钟）
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7（刷新令牌过期时间，单位：天）